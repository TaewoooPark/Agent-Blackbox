{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@agent-blackbox/core": ["packages/core/src/index.ts"],
      "@agent-blackbox/storage": ["packages/storage/src/index.ts"],
      "@agent-blackbox/opencode-adapter": ["packages/opencode-adapter/src/index.ts"]
    }
  }
}
