{
  "name": "@agent-blackbox/claude-code-adapter",
  "version": "0.1.0",
  "description": "Claude Code adapter for Agent-Blackbox (transcript tailer).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@agent-blackbox/core": "file:../core",
    "@agent-blackbox/storage": "file:../storage"
  }
}
