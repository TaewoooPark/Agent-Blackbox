{
  "name": "agent-blackbox-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first workflow recorder for coding agents.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck && npm test",
    "lint": "npm run typecheck",
    "optimize": "node apps/daemon/dist/cli.js optimize",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "up": "node apps/daemon/dist/cli.js up"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
